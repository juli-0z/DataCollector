<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- 阅读提示：主题资源：定义应用主题、状态栏、窗口背景和 Material 组件默认样式。 注释使用简体中文并按 UTF-8 保存，避免 Android Studio 中出现乱码。 -->
    <style name="Base.Theme.DataCollector" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorPrimaryVariant">@color/blue_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/blue_accent</item>
        <item name="colorSecondaryVariant">@color/warning</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/page_background</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/blue_primary_dark</item>
        <item name="android:navigationBarColor">@color/page_background</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement" tools:targetApi="35">true</item>
        <item name="toolbarStyle">@style/Widget.DataCollector.Toolbar</item>
        <item name="materialCardViewStyle">@style/Widget.DataCollector.Card</item>
        <item name="floatingActionButtonStyle">@style/Widget.DataCollector.Fab</item>
        <item name="textInputStyle">@style/Widget.DataCollector.TextInputLayout</item>
        <item name="editTextStyle">@style/Widget.DataCollector.EditText</item>
    </style>

    <style name="Theme.DataCollector" parent="Base.Theme.DataCollector" />

    <style name="Theme.DataCollector.NoActionBar" parent="Theme.DataCollector">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.DataCollector.AppBarOverlay" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar">
        <item name="colorControlNormal">@color/white</item>
    </style>

    <style name="Theme.DataCollector.PopupOverlay" parent="ThemeOverlay.MaterialComponents.Light" />

    <style name="Widget.DataCollector.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@drawable/bg_toolbar_gradient</item>
        <item name="android:minHeight">60dp</item>
        <item name="elevation">4dp</item>
        <item name="android:elevation">4dp</item>
        <item name="contentInsetStart">12dp</item>
        <item name="contentInsetStartWithNavigation">8dp</item>
        <item name="contentInsetEnd">12dp</item>
        <item name="titleMarginStart">12dp</item>
        <item name="titleMarginEnd">8dp</item>
        <item name="titleTextAppearance">@style/TextAppearance.DataCollector.Toolbar.Title</item>
        <item name="subtitleTextAppearance">@style/TextAppearance.DataCollector.Toolbar.Subtitle</item>
        <item name="titleTextColor">@color/white</item>
        <item name="subtitleTextColor">@color/blue_light</item>
        <item name="navigationIconTint">@color/white</item>
        <item name="popupTheme">@style/Theme.DataCollector.PopupOverlay</item>
    </style>

    <style name="TextAppearance.DataCollector.Toolbar.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextAppearance.DataCollector.Toolbar.Subtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textColor">@color/blue_light</item>
    </style>

    <style name="Widget.DataCollector.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">3dp</item>
    </style>

    <style name="Widget.DataCollector.Fab" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/blue_accent</item>
        <item name="tint">@color/white</item>
    </style>

    <style name="Widget.DataCollector.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface_card</item>
        <item name="boxStrokeColor">@color/divider</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>

    <style name="Widget.DataCollector.EditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>

    <style name="ShapeAppearance.DataCollector.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
</resources>
