<?xml version="1.0" encoding="utf-8"?>
<!-- 阅读提示：操作日志列表项布局：展示单条日志的时间、类型和内容。 注释使用简体中文并按 UTF-8 保存，避免 Android Studio 中出现乱码。 -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_md"
    app:cardBackgroundColor="@color/surface_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_log_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                tools:text="保存测点" />

            <TextView
                android:id="@+id/text_log_category_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_soft"
                android:paddingStart="@dimen/space_sm"
                android:paddingTop="@dimen/space_xs"
                android:paddingEnd="@dimen/space_sm"
                android:paddingBottom="@dimen/space_xs"
                android:textColor="@color/blue_primary"
                android:textStyle="bold"
                tools:text="采集" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_log_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            tools:text="2026-04-21 19:30:12" />

        <TextView
            android:id="@+id/text_log_database"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            tools:text="jjsk008.db" />

        <TextView
            android:id="@+id/text_log_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            tools:text="测线 2 · 测点 36 · 建议保存" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
