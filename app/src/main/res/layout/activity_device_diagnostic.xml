<?xml version="1.0" encoding="utf-8"?>
<!-- 阅读提示：设备联调诊断页面布局：展示 Wi-Fi、TCP、协议状态、最后命令和异常帧信息。 注释使用简体中文并按 UTF-8 保存，避免 Android Studio 中出现乱码。 -->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page_field"
    tools:context=".ui.collection.diagnostic.DeviceDiagnosticActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/blue_primary_dark">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            style="@style/Widget.DataCollector.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@color/blue_primary_dark"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:title="@string/title_device_diagnostic" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_md"
            android:paddingTop="@dimen/space_md"
            android:paddingEnd="@dimen/space_md"
            android:paddingBottom="@dimen/space_lg">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_md"
                app:cardBackgroundColor="@color/surface_card_strong">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_soft"
                        android:paddingStart="@dimen/space_sm"
                        android:paddingTop="@dimen/space_xs"
                        android:paddingEnd="@dimen/space_sm"
                        android:paddingBottom="@dimen/space_xs"
                        android:text="@string/device_diagnostic_intro_chip"
                        android:textColor="@color/blue_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_intro_title"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/device_diagnostic_intro_subtitle"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_clear_history"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_action_clear" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_md"
                app:cardBackgroundColor="@color/surface_card_strong">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/device_diagnostic_section_connection"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_state"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_state_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        tools:text="已连接" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_target"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_target_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="192.168.1.100:8080" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_wifi_state"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_wifi_state_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        tools:text="已连接" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_wifi_hotspot"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_wifi_hotspot_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="DEVICE_AP_001" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_wifi_detail"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_wifi_detail_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="热点已连接，等待 TCP 建链" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_reconnect"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_reconnect_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="0 / 3" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_latest_event"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_latest_event_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="连接成功 192.168.1.100:8080" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_updated_at"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_updated_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="2026-04-24 16:30:00" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_md"
                app:cardBackgroundColor="@color/surface_card_strong">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/device_diagnostic_section_protocol"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_protocol_state"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_protocol_state_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        tools:text="采集中" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_handshake_stage"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_handshake_stage_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="等待状态帧" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_last_command"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_last_command_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="CMD_START_COLLECTION" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_packet_count"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_packet_count_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="已发 5 / 已收 32" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_frame_count"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_frame_count_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="状态 8 / 波形 24" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_checksum_count"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_checksum_count_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="0 次" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_status_summary"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_status_summary_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="协议 采集中 | 电池 12.10V | 温度 28.0℃ | 信号 82 | GPS 2.0m" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_md"
                app:cardBackgroundColor="@color/surface_card_strong">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/device_diagnostic_section_outgoing"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_summary"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_outgoing_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textIsSelectable="true"
                        tools:text="TX CMD_SET_PARAMETERS(0x03) payload=32B crc=0x12345678" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_packet_preview"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_outgoing_hex"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textColor="@color/text_primary"
                        android:textIsSelectable="true"
                        tools:text="0000: 78 56 34 12 ..." />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_time"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_outgoing_time"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="2026-04-24 16:30:01" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_md"
                app:cardBackgroundColor="@color/surface_card_strong">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/device_diagnostic_section_incoming"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_summary"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_incoming_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textIsSelectable="true"
                        tools:text="RX WAVEFORM_DATA(0x10) payload=4096B CRC OK 0x2F91ABCD" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_packet_preview"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_incoming_hex"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textColor="@color/text_primary"
                        android:textIsSelectable="true"
                        tools:text="0000: 78 56 34 12 ..." />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_time"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_incoming_time"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="2026-04-24 16:30:05" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_md"
                app:cardBackgroundColor="@color/surface_card_strong">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/device_diagnostic_section_error"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_error"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_error_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textIsSelectable="true"
                        tools:text="Checksum mismatch ..." />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_time"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_error_time"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="2026-04-24 16:30:05" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_error_frame_summary"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_error_frame_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textIsSelectable="true"
                        tools:text="RX DEVICE_STATUS(0x11) CRC mismatch" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_error_frame_preview"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_error_frame_hex"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textColor="@color/text_primary"
                        android:textIsSelectable="true"
                        tools:text="0000: 78 56 34 12 ..." />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/device_diagnostic_label_error_frame_time"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/text_error_frame_time"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="2026-04-24 16:30:05" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_card_strong">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/device_diagnostic_section_events"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_event_log"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:fontFamily="monospace"
                        android:textColor="@color/text_primary"
                        android:textIsSelectable="true"
                        tools:text="16:30:00  连接状态 -> 已连接" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
